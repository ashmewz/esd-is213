{
  "openapi": "3.0.3",
  "info": {
    "title": "Events Service API",
    "version": "1.0.0",
    "description": "API for managing concert events and seat information"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local Kong API gateway"
    }
  ],
  "tags": [
    {
      "name": "Events",
      "description": "Event management endpoints"
    }
  ],
  "paths": {
    "/events": {
      "get": {
        "tags": ["Events"],
        "summary": "List events",
        "operationId": "listEvents",
        "responses": {
          "200": {
            "description": "Events retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Event"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/events/{event_id}": {
      "get": {
        "tags": ["Events"],
        "summary": "Get event by id",
        "operationId": "getEvent",
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          }
        ],
        "responses": {
          "200": {
            "description": "Event retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/events/{event_id}/seats": {
      "get": {
        "tags": ["Events"],
        "summary": "List seats for an event",
        "operationId": "listEventSeats",
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          }
        ],
        "responses": {
          "200": {
            "description": "Seats retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Seat"
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/events/{event_id}/seats/{seat_id}": {
      "get": {
        "tags": ["Events"],
        "summary": "Get seat details",
        "operationId": "getSeat",
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          },
          {
            "$ref": "#/components/parameters/SeatId"
          }
        ],
        "responses": {
          "200": {
            "description": "Seat retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Seat"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/events/{event_id}/seats/{seat_id}/status": {
      "put": {
        "tags": ["Events"],
        "summary": "Update seat status",
        "operationId": "updateSeatStatus",
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          },
          {
            "$ref": "#/components/parameters/SeatId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["available", "held", "sold", "blocked", "removed"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Seat status updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Seat"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/events/{event_id}/seatmap": {
      "put": {
        "tags": ["Events"],
        "summary": "Remove seats from seatmap",
        "operationId": "updateSeatmap",
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["removedSeatIds"],
                "properties": {
                  "removedSeatIds": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "format": "uuid"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Seatmap updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "eventId": {
                      "type": "string"
                    },
                    "seatmapVersion": {
                      "type": "integer"
                    },
                    "removedSeats": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "availableSeats": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/events/{event_id}/seats/restore": {
      "put": {
        "tags": ["Events"],
        "summary": "Restore previously removed seats",
        "operationId": "restoreSeats",
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["seatIds"],
                "properties": {
                  "seatIds": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "format": "uuid"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Seats restored",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "restoredSeats": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "EventId": {
        "name": "event_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "SeatId": {
        "name": "seat_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "Event": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "venueId": {
            "type": "string",
            "format": "uuid"
          },
          "venueName": {
            "type": "string"
          },
          "eventDate": {
            "type": "string"
          },
          "eventTiming": {
            "type": "string"
          }
        }
      },
      "Seat": {
        "type": "object",
        "properties": {
          "seatId": {
            "type": "string",
            "format": "uuid"
          },
          "eventId": {
            "type": "string",
            "format": "uuid"
          },
          "sectionNo": {
            "type": "integer",
            "nullable": true
          },
          "rowNo": {
            "type": "integer",
            "nullable": true
          },
          "seatNo": {
            "type": "integer",
            "nullable": true
          },
          "tier": {
            "type": "string"
          },
          "basePrice": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": ["available", "held", "sold", "blocked", "removed"]
          }
        }
      }
    }
  }
}
