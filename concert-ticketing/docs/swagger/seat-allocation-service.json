{
  "openapi": "3.0.3",
  "info": {
    "title": "Seat Allocation Service API",
    "version": "1.0.0",
    "description": "API for managing seat holds and seat allocations"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local Kong API gateway"
    }
  ],
  "tags": [
    {
      "name": "Seat Allocation",
      "description": "Seat hold and allocation endpoints"
    }
  ],
  "paths": {
    "/holds": {
      "post": {
        "tags": ["Seat Allocation"],
        "summary": "Create hold for a seat",
        "operationId": "createHold",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateHoldRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Hold created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "409": {
            "description": "Hold conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/holds/{hold_id}": {
      "delete": {
        "tags": ["Seat Allocation"],
        "summary": "Cancel hold",
        "operationId": "cancelHold",
        "parameters": [
          {
            "name": "hold_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Hold cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "description": "Hold cannot be cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/holds/{hold_id}/confirm": {
      "post": {
        "tags": ["Seat Allocation"],
        "summary": "Confirm hold to sold seat assignment",
        "operationId": "confirmHold",
        "parameters": [
          {
            "name": "hold_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["transactionId"],
                "properties": {
                  "transactionId": {
                    "type": "string",
                    "format": "uuid"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Hold confirmed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "description": "Cannot confirm hold",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/seat-assignments": {
      "get": {
        "tags": ["Seat Allocation"],
        "summary": "List sold seat assignments for a user",
        "operationId": "listSeatAssignments",
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Seat assignments retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SeatAssignment"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    }
  },
  "components": {
    "responses": {
      "BadRequest": {
        "description": "Invalid request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "CreateHoldRequest": {
        "type": "object",
        "required": ["orderId", "eventId", "seatId", "ttlSeconds"],
        "properties": {
          "orderId": {
            "type": "integer"
          },
          "eventId": {
            "type": "string",
            "format": "uuid"
          },
          "seatId": {
            "type": "string",
            "format": "uuid"
          },
          "ttlSeconds": {
            "type": "integer",
            "minimum": 1
          },
          "userId": {
            "type": "string"
          }
        }
      },
      "SeatAssignment": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "integer"
          },
          "eventId": {
            "type": "string",
            "format": "uuid"
          },
          "seatId": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "type": "string"
          },
          "tier": {
            "type": "string"
          },
          "sectionNo": {
            "type": "integer",
            "nullable": true
          },
          "rowNo": {
            "type": "integer",
            "nullable": true
          },
          "seatNo": {
            "type": "integer",
            "nullable": true
          },
          "seatLabel": {
            "type": "string"
          }
        }
      }
    }
  }
}
