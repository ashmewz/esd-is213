                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/events/{event_id}/seats/{seat_id}/status": {
      "put": {
        "tags": ["Events"],
        "summary": "Update seat status",
        "operationId": "updateSeatStatus",
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          },
          {
            "$ref": "#/components/parameters/SeatId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["available", "held", "sold", "blocked", "removed"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Seat status updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Seat"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/events/{event_id}/seatmap": {
      "put": {
        "tags": ["Events"],
        "summary": "Remove seats from seatmap",
        "operationId": "updateSeatmap",
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["removedSeatIds"],
                "properties": {
                  "removedSeatIds": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "format": "uuid"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Seatmap updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "eventId": {
                      "type": "string"
                    },
                    "seatmapVersion": {
                      "type": "integer"
                    },
                    "removedSeats": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "availableSeats": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/events/{event_id}/seats/restore": {
      "put": {
        "tags": ["Events"],
        "summary": "Restore previously removed seats",
        "operationId": "restoreSeats",
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          }
