{
  "openapi": "3.0.3",
  "info": {
    "title": "StagePass Concert Ticketing API",
    "version": "1.0.0",
    "description": "Consolidated API documentation for the concert-ticketing microservices exposed through Kong.\n\nBase gateway URL: http://localhost:8000\n\nOutSystems Order base URL: https://personal-v9ndj4pt.outsystemscloud.com/Order/rest/Order"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local Kong API gateway"
    }
  ],
  "tags": [
    {
      "name": "Events"
    },
    {
      "name": "Users"
    },
    {
      "name": "Booking"
    },
    {
      "name": "Seat Allocation"
    },
    {
      "name": "Swaps"
    },
    {
      "name": "Payments"
    },
    {
      "name": "OutSystems Orders"
    }
  ],
  "paths": {
    "/events": {
      "get": {
        "tags": ["Events"],
        "summary": "List events",
        "operationId": "listEvents",
        "responses": {
          "200": {
            "description": "Events retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Event"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/events/{event_id}": {
      "get": {
        "tags": ["Events"],
        "summary": "Get event by id",
        "operationId": "getEvent",
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          }
        ],
        "responses": {
          "200": {
            "description": "Event retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/events/{event_id}/seats": {
      "get": {
        "tags": ["Events"],
