{
  "openapi": "3.0.3",
  "info": {
    "title": "Swap Service API",
    "version": "1.0.0",
    "description": "API for managing peer-to-peer ticket swaps"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local Kong API gateway"
    }
  ],
  "tags": [
    {
      "name": "Swaps",
      "description": "Ticket swap operations"
    }
  ],
  "paths": {
    "/swap-requests": {
      "get": {
        "tags": ["Swaps"],
        "summary": "List swap requests by user",
        "operationId": "listSwapRequests",
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Swap requests retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      },
      "post": {
        "tags": ["Swaps"],
        "summary": "Create swap request",
        "operationId": "createSwapRequest",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSwapRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Swap request created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/swap-requests/available": {
      "get": {
        "tags": ["Swaps"],
        "summary": "List available swap requests for matching",
        "operationId": "listAvailableSwapRequests",
        "parameters": [
          {
            "name": "eventId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "tier",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "excludeUserId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Available swap requests retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/swap-requests/{request_id}": {
      "delete": {
        "tags": ["Swaps"],
        "summary": "Cancel swap request",
        "operationId": "cancelSwapRequest",
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Swap request cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Cannot cancel request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/swap-matches/{swap_id}/response": {
      "post": {
        "tags": ["Swaps"],
        "summary": "Respond to a proposed swap match",
        "operationId": "respondToSwapMatch",
        "parameters": [
          {
            "name": "swap_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SwapResponseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response submitted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/swap/{swap_id}": {
      "get": {
        "tags": ["Swaps"],
        "summary": "Get swap status",
        "operationId": "getSwapStatus",
        "parameters": [
          {
            "name": "swap_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Swap status retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "responses": {
      "BadRequest": {
        "description": "Invalid request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "CreateSwapRequest": {
        "type": "object",
        "required": ["userId", "orderId", "eventId", "currentSeatId", "desiredTier"],
        "properties": {
          "userId": {
            "type": "string"
          },
          "orderId": {
            "type": "integer"
          },
          "eventId": {
            "type": "string",
            "format": "uuid"
          },
          "currentSeatId": {
            "type": "string",
            "format": "uuid"
          },
          "currentTier": {
            "type": "string"
          },
          "desiredTier": {
            "type": "string"
          }
        }
      },
      "SwapResponseRequest": {
        "type": "object",
        "required": ["userId", "response"],
        "properties": {
          "userId": {
            "type": "string"
          },
          "response": {
            "type": "string",
            "enum": ["ACCEPT", "DECLINE"]
          }
        }
      }
    }
  }
}
